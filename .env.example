# ═══════════════════════════════════════════
#  LLM Configuration (Groq - FREE, no Ollama needed!)
# ═══════════════════════════════════════════
# Get free API key at: https://console.groq.com/keys
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant

# Alternative: Ollama (requires 8GB+ RAM)
# LLM_PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434
# LLM_MODEL=hermes3:latest

# ═══════════════════════════════════════════
#  Telegram Bridge (Hermes as Boss)
# ═══════════════════════════════════════════
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Your chat ID with the bot (send /start, then check getUpdates)
TELEGRAM_CHAT_ID=your-chat-id-here

# Auto-report interval in ms (0 = disabled, 300000 = every 5 min)
TELEGRAM_REPORT_INTERVAL=0

# ═══════════════════════════════════════════
#  Server
# ═══════════════════════════════════════════
# Default: 4890 (uncommon port to avoid conflicts with existing services)
PORT=4890

# Optional: Tavily for web search
# TAVILY_API_KEY=your-tavily-key
