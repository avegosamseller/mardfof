# ============================================
# LLM Provider Configuration
# ============================================
# Choose provider: "groq" (default) or "ollama"
LLM_PROVIDER=groq

# Model to use (default varies by provider)
# Groq models: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768, gemma2-9b-it
# Ollama models: hermes3:latest, llama3:latest, etc.
LLM_MODEL=llama-3.3-70b-versatile

# ============================================
# Groq Configuration (when LLM_PROVIDER=groq)
# ============================================
# Get your API key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ============================================
# Ollama Configuration (when LLM_PROVIDER=ollama)
# ============================================
OLLAMA_URL=http://localhost:11434

# ============================================
# Optional: Tavily for web search tool
# ============================================
# TAVILY_API_KEY=your-tavily-key

# ============================================
# Server
# ============================================
PORT=3000
